# ===================================
# Portfolio - Environment Template
# ===================================
# Copy this file to `.env` and fill in real values.
# For per-machine overrides, create `.env.local` (also gitignored).
#
# Loading order (Next.js): .env.local -> .env.<NODE_ENV> -> .env

# ---- App state ----
# Selects which MongoDB URI is used at runtime.
# Valid values: dev | local | prod
# Default: prod
APP_STATE=prod

# ---- MongoDB URIs (one per environment) ----
# The app uses MONGODB_URI_<APP_STATE upper-cased>.
MONGODB_URI_DEV=mongodb+srv://<user>:<password>@<dev-cluster>/<db>
MONGODB_URI_LOCAL=mongodb://localhost:27017/<db>
MONGODB_URI_PROD=mongodb://<user>:<password>@<prod-host>:27017/<db>?authSource=<db>

# ---- App ----
NEXT_PUBLIC_SITE_NAME=Sayantan Kar Portfolio
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- Auth (NextAuth) ----
NEXTAUTH_SECRET=replace-with-a-long-random-string
NEXTAUTH_URL=http://localhost:3000
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# ---- SMTP ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
CONTACT_EMAIL=your-email@gmail.com
